# Copy to .env and fill in real values. .env is gitignored (see *.env rule).

# SQL Server connection string for the existing MSSQL instance on your LAN.
# Do not use "localhost" - containers can't reach the host via localhost.
ConnectionStrings__DefaultConnection=Server=<lan-ip-or-hostname>;Database=Dollars2;User Id=<user>;Password=<password>;TrustServerCertificate=True;

# Random secret used to sign JWTs (e.g. `openssl rand -base64 48`)
Jwt__Secret=

# Origin the frontend is served from, e.g. your Tailscale hostname/IP + frontend port
Cors__FrontendUrl=http://<tailscale-host>:8080

# App-wide Serilog minimum level. One of: Verbose, Debug, Information, Warning, Error, Fatal.
# Defaults to Information if unset. (Microsoft.AspNetCore stays pinned at Warning regardless.)
Serilog__MinimumLevel=Information

Plaid__ClientId=
Plaid__Secret=

# Backend origin the frontend's built JS will call - baked in at build time
VITE_API_BASE_URL=http://<tailscale-host>:5062
