{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "<dotnet user secret>"
  },
  "Jwt": {
    "Secret": "<dotnet user secret>",
    "Issuer": "Dollars2",
    "Audience": "Dollars2",
    "ExpirationDays": 30
  },
  "Cors": {
    "FrontendUrl": "http://localhost:5173"
  },
  "SimpleFin": {
    "Enabled": false,
    "MinSyncIntervalHours": 6
  },
  "Plaid": {
    "Enabled": false,
    "ClientId": "<dotnet user secret>",
    "Secret": "<dotnet user secret>",
    "Environment": "Production",
    "MinSyncIntervalHours": 6
  }
}
